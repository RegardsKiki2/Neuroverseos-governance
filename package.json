{
  "name": "@neuroverseos/governance",
  "version": "0.2.1",
  "description": "Deterministic governance engine for AI agents — enforce worlds (permanent rules) and plans (mission constraints) with full audit trace",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js",
      "require": "./dist/adapters/index.cjs"
    },
    "./adapters/langchain": {
      "types": "./dist/adapters/langchain.d.ts",
      "import": "./dist/adapters/langchain.js",
      "require": "./dist/adapters/langchain.cjs"
    },
    "./adapters/openai": {
      "types": "./dist/adapters/openai.d.ts",
      "import": "./dist/adapters/openai.js",
      "require": "./dist/adapters/openai.cjs"
    },
    "./adapters/openclaw": {
      "types": "./dist/adapters/openclaw.d.ts",
      "import": "./dist/adapters/openclaw.js",
      "require": "./dist/adapters/openclaw.cjs"
    },
    "./adapters/express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.js",
      "require": "./dist/adapters/express.cjs"
    },
    "./plan": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "neuroverse": "dist/cli/neuroverse.js"
  },
  "files": [
    "dist",
    "dist/worlds",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli/neuroverse.ts src/cli/plan.ts src/cli/run.ts src/adapters/index.ts src/adapters/langchain.ts src/adapters/openai.ts src/adapters/openclaw.ts src/adapters/express.ts --format esm,cjs --dts --clean && cp src/worlds/derivation-world.nv-world.md dist/worlds/derivation-world.nv-world.md",
    "prebuild": "mkdir -p dist/worlds",
    "dev": "tsup src/index.ts src/cli/neuroverse.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "neuroverse",
    "governance",
    "guard",
    "deterministic",
    "rule-engine",
    "ai-governance",
    "ai-agents",
    "compliance",
    "audit",
    "world-engine",
    "plan-enforcement",
    "agent-governance",
    "ai-safety",
    "openclaw-plugin",
    "langchain-plugin",
    "drift-prevention",
    "mcp",
    "mcp-server",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NeuroverseOS/Neuroverseos-governance.git"
  },
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://neuroverseos.com"
}
