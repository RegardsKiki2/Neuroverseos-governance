{
  "name": "neuroverse-governance",
  "version": "0.1.0",
  "description": "Deterministic governance engine for AI agents — evaluate events against world definitions with full audit trace",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "neuroverse": "./dist/cli/neuroverse.js"
  },
  "files": [
    "dist",
    "dist/worlds",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli/neuroverse.ts --format esm,cjs --dts --clean && cp src/worlds/derivation-world.nv-world.md dist/worlds/derivation-world.nv-world.md",
    "prebuild": "mkdir -p dist/worlds",
    "dev": "tsup src/index.ts src/cli/neuroverse.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "neuroverse",
    "governance",
    "guard",
    "deterministic",
    "rule-engine",
    "ai-governance",
    "ai-agents",
    "compliance",
    "audit",
    "world-engine"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/neuroverseos/neuroverseos-governance"
  },
  "homepage": "https://neuroverseos.com"
}
